// Paste this into Firebase Console → Firestore Database → Rules.
// Each user can only read/write their own subtree.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/activities/{activityId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/meta/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // FCM push tokens for this user's devices. Each token doc id = the token.
    match /users/{userId}/devices/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
